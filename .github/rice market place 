<div class="container" style="margin-top: 20px;">
    <h3>Rice Price Calculator</h3>
    <p>Select your rice type and enter the weight to see the total price.</p>
    
    <label for="rice-type">Rice Type:</label>
    <select id="rice-type">
        <option value="2500">Super Biryani (2,500 TZS/kg)</option>
        <option value="2000">Grade A Mbeya (2,000 TZS/kg)</option>
        <option value="1800">Standard White (1,800 TZS/kg)</option>
    </select>

    <label for="kg-amount">Amount (Kilograms):</label>
    <input type="number" id="kg-amount" placeholder="Enter kg" oninput="calculatePrice()">

    <div style="background: #eee; padding: 10px; margin-top: 10px; border-radius: 5px;">
        <strong>Total Price: <span id="total-display">0</span> TZS</strong>
    </div>
</div>

<script>
function calculatePrice() {
    const pricePerKg = document.getElementById('rice-type').value;
    const kg = document.getElementById('kg-amount').value;
    const display = document.getElementById('total-display');
    
    if (kg > 0) {
        display.innerText = (pricePerKg * kg).toLocaleString(); // .toLocaleString adds commas to numbers
    } else {
        display.innerText = "0";
    }
}
</script>
/* Gallery Layout */
.gallery-grid {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 20px;
}

.rice-card {
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    width: 200px;
    text-align: center;
    padding: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.rice-card img {
    width: 100%;
    height: 150px;
    object-fit: cover; /* Keeps images looking professional */
    border-radius: 4px;
}
